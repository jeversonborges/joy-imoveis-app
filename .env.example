# ============================================================
# Supabase — obrigatório
# Obtenha em: https://supabase.com/dashboard -> seu projeto -> Settings -> API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ImoveisApp

# ============================================================
# Nominatim (OpenStreetMap geocoding) — sem API key necessária
# Apenas identifique seu app para respeitar os termos de uso
# ============================================================
NEXT_PUBLIC_NOMINATIM_USER_AGENT=imoveisapp/1.0 (seu@email.com)

# ============================================================
# OAuth — configurados no Supabase Dashboard, NÃO aqui
# Supabase > Authentication > Providers
#
# Google:    GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
# Facebook:  FACEBOOK_APP_ID + FACEBOOK_APP_SECRET
# Instagram: via Facebook Login (mesmas credenciais + scope instagram_basic)
# ============================================================
